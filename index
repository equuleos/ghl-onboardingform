<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Client Onboarding Form</title>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #0a0c10;
      --surface: #111318;
      --surface2: #181c24;
      --border: #1f2535;
      --accent: #3d7fff;
      --accent2: #7c5cfc;
      --accent-glow: rgba(61,127,255,0.18);
      --text: #e8ecf4;
      --muted: #6b7695;
      --label: #a0aac4;
      --success: #22d3a5;
      --radius: 12px;
      --transition: 0.22s cubic-bezier(.4,0,.2,1);
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      padding: 0 0 80px;
      font-size: 15px;
      line-height: 1.6;
    }

    /* HEADER */
    .form-header {
      background: linear-gradient(135deg, #0d1220 0%, #111827 60%, #0e1525 100%);
      border-bottom: 1px solid var(--border);
      padding: 56px 24px 40px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .form-header::before {
      content: '';
      position: absolute;
      top: -60px; left: 50%;
      transform: translateX(-50%);
      width: 600px; height: 300px;
      background: radial-gradient(ellipse at center, rgba(61,127,255,0.12) 0%, transparent 70%);
      pointer-events: none;
    }
    .form-header .badge {
      display: inline-block;
      font-family: 'Syne', sans-serif;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--accent);
      background: rgba(61,127,255,0.10);
      border: 1px solid rgba(61,127,255,0.22);
      border-radius: 100px;
      padding: 5px 16px;
      margin-bottom: 20px;
    }
    .form-header h1 {
      font-family: 'Syne', sans-serif;
      font-size: clamp(26px, 5vw, 44px);
      font-weight: 800;
      letter-spacing: -0.02em;
      background: linear-gradient(135deg, #e8ecf4 30%, #7c9fd4 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: 12px;
    }
    .form-header p {
      color: var(--muted);
      font-size: 15px;
      max-width: 480px;
      margin: 0 auto;
    }

    /* PROGRESS BAR */
    .progress-wrap {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(10,12,16,0.92);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
      padding: 14px 24px;
      display: flex;
      align-items: center;
      gap: 14px;
    }
    .progress-bar-bg {
      flex: 1;
      height: 4px;
      background: var(--border);
      border-radius: 100px;
      overflow: hidden;
    }
    .progress-bar-fill {
      height: 100%;
      background: linear-gradient(90deg, var(--accent), var(--accent2));
      border-radius: 100px;
      transition: width 0.5s cubic-bezier(.4,0,.2,1);
      width: 0%;
    }
    .progress-label {
      font-family: 'Syne', sans-serif;
      font-size: 12px;
      font-weight: 600;
      color: var(--muted);
      white-space: nowrap;
    }

    /* FORM LAYOUT */
    form {
      max-width: 760px;
      margin: 0 auto;
      padding: 40px 20px 0;
    }

    /* SECTION CARD */
    .section-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 18px;
      margin-bottom: 28px;
      overflow: hidden;
      transition: border-color var(--transition);
    }
    .section-card:focus-within {
      border-color: rgba(61,127,255,0.35);
    }

    .section-head {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 20px 24px;
      border-bottom: 1px solid var(--border);
      background: var(--surface2);
    }
    .section-num {
      width: 32px; height: 32px;
      border-radius: 10px;
      background: linear-gradient(135deg, var(--accent), var(--accent2));
      display: flex; align-items: center; justify-content: center;
      font-family: 'Syne', sans-serif;
      font-size: 13px;
      font-weight: 700;
      color: #fff;
      flex-shrink: 0;
    }
    .section-title {
      font-family: 'Syne', sans-serif;
      font-size: 14px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--label);
    }

    .section-body {
      padding: 24px;
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    /* FIELD GROUPS */
    .field-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }
    @media (max-width: 560px) {
      .field-row { grid-template-columns: 1fr; }
    }

    .field {
      display: flex;
      flex-direction: column;
      gap: 7px;
    }
    .field label {
      font-size: 13px;
      font-weight: 500;
      color: var(--label);
      letter-spacing: 0.01em;
    }
    .field label .req {
      color: var(--accent);
      margin-left: 3px;
    }

    input[type="text"],
    input[type="email"],
    input[type="tel"],
    input[type="url"],
    input[type="number"],
    textarea,
    select {
      width: 100%;
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      color: var(--text);
      font-family: 'DM Sans', sans-serif;
      font-size: 14.5px;
      padding: 11px 14px;
      outline: none;
      transition: border-color var(--transition), box-shadow var(--transition);
      -webkit-appearance: none;
    }
    input:focus, textarea:focus, select:focus {
      border-color: var(--accent);
      box-shadow: 0 0 0 3px var(--accent-glow);
    }
    input::placeholder, textarea::placeholder {
      color: var(--muted);
      font-size: 13.5px;
    }
    textarea {
      resize: vertical;
      min-height: 100px;
    }
    select option {
      background: var(--surface);
    }

    /* RADIO / CHECKBOX GROUPS */
    .choice-group {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }
    .choice-item {
      position: relative;
    }
    .choice-item input[type="radio"],
    .choice-item input[type="checkbox"] {
      position: absolute;
      opacity: 0;
      width: 0; height: 0;
    }
    .choice-item label {
      display: flex;
      align-items: center;
      gap: 8px;
      cursor: pointer;
      padding: 9px 16px;
      border-radius: 100px;
      border: 1px solid var(--border);
      background: var(--bg);
      font-size: 13.5px;
      font-weight: 400;
      color: var(--muted);
      transition: all var(--transition);
      user-select: none;
      white-space: nowrap;
    }
    .choice-item label:hover {
      border-color: rgba(61,127,255,0.4);
      color: var(--text);
    }
    .choice-item input:checked + label {
      background: rgba(61,127,255,0.12);
      border-color: var(--accent);
      color: var(--accent);
      font-weight: 500;
    }
    .choice-item label .dot {
      width: 14px; height: 14px;
      border-radius: 50%;
      border: 2px solid currentColor;
      flex-shrink: 0;
      display: flex; align-items: center; justify-content: center;
      transition: all var(--transition);
    }
    .choice-item input[type="radio"]:checked + label .dot::after {
      content: '';
      width: 6px; height: 6px;
      border-radius: 50%;
      background: var(--accent);
    }
    .choice-item label .box {
      width: 14px; height: 14px;
      border-radius: 4px;
      border: 2px solid currentColor;
      flex-shrink: 0;
      display: flex; align-items: center; justify-content: center;
      transition: all var(--transition);
    }
    .choice-item input[type="checkbox"]:checked + label .box::after {
      content: '✓';
      font-size: 10px;
      line-height: 1;
      color: var(--accent);
    }

    /* FIELD LABEL PLAIN */
    .field-label {
      font-size: 13px;
      font-weight: 500;
      color: var(--label);
      margin-bottom: 4px;
      display: block;
    }

    /* SUBMIT */
    .submit-wrap {
      max-width: 760px;
      margin: 8px auto 0;
      padding: 0 20px;
    }
    .submit-btn {
      width: 100%;
      padding: 16px;
      background: linear-gradient(135deg, var(--accent) 0%, var(--accent2) 100%);
      color: #fff;
      border: none;
      border-radius: var(--radius);
      font-family: 'Syne', sans-serif;
      font-size: 16px;
      font-weight: 700;
      letter-spacing: 0.03em;
      cursor: pointer;
      transition: opacity var(--transition), transform var(--transition), box-shadow var(--transition);
      box-shadow: 0 4px 24px rgba(61,127,255,0.25);
      position: relative;
      overflow: hidden;
    }
    .submit-btn:hover {
      opacity: 0.92;
      transform: translateY(-1px);
      box-shadow: 0 8px 32px rgba(61,127,255,0.35);
    }
    .submit-btn:active { transform: translateY(0); }
    .submit-btn:disabled { opacity: 0.55; cursor: not-allowed; transform: none; }

    /* SUCCESS */
    #success-msg {
      display: none;
      max-width: 760px;
      margin: 32px auto;
      padding: 0 20px;
    }
    .success-card {
      background: linear-gradient(135deg, rgba(34,211,165,0.08), rgba(61,127,255,0.08));
      border: 1px solid rgba(34,211,165,0.25);
      border-radius: 18px;
      padding: 40px 32px;
      text-align: center;
    }
    .success-icon {
      font-size: 48px;
      margin-bottom: 16px;
    }
    .success-card h2 {
      font-family: 'Syne', sans-serif;
      font-size: 22px;
      font-weight: 700;
      color: var(--success);
      margin-bottom: 8px;
    }
    .success-card p { color: var(--muted); }

    /* DIVIDER */
    .field-divider {
      height: 1px;
      background: var(--border);
      margin: 4px 0;
    }

    /* Scroll smooth */
    html { scroll-behavior: smooth; }
  </style>
</head>
<body>

<div class="form-header">
  <div class="badge">Client Onboarding</div>
  <h1>Tell Us About Your Business</h1>
  <p>Fill out the form below so we can set up your system exactly the way you need it.</p>
</div>

<div class="progress-wrap">
  <div class="progress-bar-bg">
    <div class="progress-bar-fill" id="progressBar"></div>
  </div>
  <span class="progress-label" id="progressLabel">0% complete</span>
</div>

<form id="mainForm" action="https://formspree.io/f/mpqoaokj" method="POST">

  <!-- SECTION 1 -->
  <div class="section-card">
    <div class="section-head">
      <div class="section-num">1</div>
      <div class="section-title">Basic Info</div>
    </div>
    <div class="section-body">
      <div class="field-row">
        <div class="field">
          <label>Business Name <span class="req">*</span></label>
          <input type="text" name="business_name" placeholder="e.g. Apex Lending LLC" required />
        </div>
        <div class="field">
          <label>Owner / Main Contact</label>
          <input type="text" name="owner_contact" placeholder="Full name" />
        </div>
      </div>
      <div class="field-row">
        <div class="field">
          <label>Email Address <span class="req">*</span></label>
          <input type="email" name="email" placeholder="you@example.com" required />
        </div>
        <div class="field">
          <label>Phone Number</label>
          <input type="tel" name="phone" placeholder="+1 (555) 000-0000" />
        </div>
      </div>
      <div class="field-row">
        <div class="field">
          <label>Business Location</label>
          <input type="text" name="location" placeholder="City, State / Country" />
        </div>
        <div class="field">
          <label>Timezone</label>
          <input type="text" name="timezone" placeholder="e.g. EST, PST, UTC+8" />
        </div>
      </div>
      <div class="field-row">
        <div class="field">
          <label>Website (if any)</label>
          <input type="url" name="website" placeholder="https://yourwebsite.com" />
        </div>
        <div class="field">
          <label>Domain Name</label>
          <input type="text" name="domain" placeholder="yourwebsite.com" />
        </div>
      </div>
    </div>
  </div>

  <!-- SECTION 2 -->
  <div class="section-card">
    <div class="section-head">
      <div class="section-num">2</div>
      <div class="section-title">Branding</div>
    </div>
    <div class="section-body">
      <div class="field">
        <span class="field-label">Do you have a logo?</span>
        <div class="choice-group">
          <div class="choice-item">
            <input type="radio" name="has_logo" id="logo_yes" value="Yes" />
            <label for="logo_yes"><span class="dot"></span> Yes</label>
          </div>
          <div class="choice-item">
            <input type="radio" name="has_logo" id="logo_no" value="No" />
            <label for="logo_no"><span class="dot"></span> No</label>
          </div>
        </div>
      </div>
      <div class="field-row">
        <div class="field">
          <label>Preferred Colors</label>
          <input type="text" name="preferred_colors" placeholder="e.g. Navy blue, gold, white" />
        </div>
        <div class="field">
          <label>Style Preference</label>
          <input type="text" name="style_preference" placeholder="e.g. Modern, corporate, minimal" />
        </div>
      </div>
      <div class="field">
        <label>Reference Websites</label>
        <input type="text" name="reference_websites" placeholder="Links to sites you like" />
      </div>
    </div>
  </div>

  <!-- SECTION 3 -->
  <div class="section-card">
    <div class="section-head">
      <div class="section-num">3</div>
      <div class="section-title">Business Overview</div>
    </div>
    <div class="section-body">
      <div class="field">
        <label>What does your business do?</label>
        <textarea name="business_description" placeholder="Describe your business in detail..."></textarea>
      </div>
      <div class="field">
        <label>Services / Products Offered</label>
        <textarea name="services_products" placeholder="List your main services or products..."></textarea>
      </div>
      <div class="field">
        <label>Target Audience</label>
        <textarea name="target_audience" placeholder="Who are your ideal clients or customers?"></textarea>
      </div>
      <div class="field">
        <label>Unique Selling Proposition</label>
        <input type="text" name="usp" placeholder="What makes you different?" />
      </div>
    </div>
  </div>

  <!-- SECTION 4 -->
  <div class="section-card">
    <div class="section-head">
      <div class="section-num">4</div>
      <div class="section-title">Goals</div>
    </div>
    <div class="section-body">
      <div class="field">
        <span class="field-label">What is your goal? (Select all that apply)</span>
        <div class="choice-group">
          <div class="choice-item">
            <input type="checkbox" name="goal[]" id="goal_leads" value="Generate leads" />
            <label for="goal_leads"><span class="box"></span> Generate leads</label>
          </div>
          <div class="choice-item">
            <input type="checkbox" name="goal[]" id="goal_followup" value="Automate follow-ups" />
            <label for="goal_followup"><span class="box"></span> Automate follow-ups</label>
          </div>
          <div class="choice-item">
            <input type="checkbox" name="goal[]" id="goal_appt" value="Book appointments" />
            <label for="goal_appt"><span class="box"></span> Book appointments</label>
          </div>
          <div class="choice-item">
            <input type="checkbox" name="goal[]" id="goal_sales" value="Close sales" />
            <label for="goal_sales"><span class="box"></span> Close sales</label>
          </div>
        </div>
      </div>
      <div class="field-row">
        <div class="field">
          <label>Monthly Lead Target</label>
          <input type="text" name="monthly_lead_target" placeholder="e.g. 50 leads/month" />
        </div>
        <div class="field">
          <label>Monthly Revenue Goal</label>
          <input type="text" name="monthly_revenue_goal" placeholder="e.g. $25,000/month" />
        </div>
      </div>
      <div class="field">
        <label>Long-term Vision</label>
        <textarea name="long_term_vision" placeholder="Where do you see your business in 1–3 years?"></textarea>
      </div>
    </div>
  </div>

  <!-- SECTION 5 -->
  <div class="section-card">
    <div class="section-head">
      <div class="section-num">5</div>
      <div class="section-title">CRM</div>
    </div>
    <div class="section-body">
      <div class="field">
        <span class="field-label">Do you have an existing CRM?</span>
        <div class="choice-group">
          <div class="choice-item">
            <input type="radio" name="has_crm" id="crm_yes" value="Yes" />
            <label for="crm_yes"><span class="dot"></span> Yes</label>
          </div>
          <div class="choice-item">
            <input type="radio" name="has_crm" id="crm_no" value="No" />
            <label for="crm_no"><span class="dot"></span> No</label>
          </div>
        </div>
      </div>
      <div class="field">
        <label>Number of Contacts</label>
        <input type="number" name="num_contacts" placeholder="e.g. 500" />
      </div>
      <div class="field">
        <span class="field-label">Fields needed:</span>
        <div class="choice-group">
          <div class="choice-item">
            <input type="checkbox" name="crm_fields[]" id="crm_loan_amount" value="Loan Amount" />
            <label for="crm_loan_amount"><span class="box"></span> Loan Amount</label>
          </div>
          <div class="choice-item">
            <input type="checkbox" name="crm_fields[]" id="crm_loan_type" value="Loan Type" />
            <label for="crm_loan_type"><span class="box"></span> Loan Type</label>
          </div>
          <div class="choice-item">
            <input type="checkbox" name="crm_fields[]" id="crm_immigration" value="Immigration Status" />
            <label for="crm_immigration"><span class="box"></span> Immigration Status</label>
          </div>
          <div class="choice-item">
            <input type="checkbox" name="crm_fields[]" id="crm_lead_source" value="Lead Source" />
            <label for="crm_lead_source"><span class="box"></span> Lead Source</label>
          </div>
          <div class="choice-item">
            <input type="checkbox" name="crm_fields[]" id="crm_pipeline" value="Pipeline Stage" />
            <label for="crm_pipeline"><span class="box"></span> Pipeline Stage</label>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- SECTION 6 -->
  <div class="section-card">
    <div class="section-head">
      <div class="section-num">6</div>
      <div class="section-title">Pipeline</div>
    </div>
    <div class="section-body">
      <div class="field">
        <label>Describe your sales process</label>
        <textarea name="sales_process" placeholder="Walk us through each step of how you acquire and close clients..."></textarea>
      </div>
      <div class="field">
        <label>Pipeline Stages</label>
        <input type="text" name="pipeline_stages" placeholder="e.g. New Lead → Contacted → Qualified → Closed" />
      </div>
    </div>
  </div>

  <!-- SECTION 7 -->
  <div class="section-card">
    <div class="section-head">
      <div class="section-num">7</div>
      <div class="section-title">Website</div>
    </div>
    <div class="section-body">
      <div class="field">
        <span class="field-label">Do you need a website?</span>
        <div class="choice-group">
          <div class="choice-item">
            <input type="radio" name="need_website" id="web_yes" value="Yes" />
            <label for="web_yes"><span class="dot"></span> Yes</label>
          </div>
          <div class="choice-item">
            <input type="radio" name="need_website" id="web_no" value="No" />
            <label for="web_no"><span class="dot"></span> No</label>
          </div>
        </div>
      </div>
      <div class="field">
        <span class="field-label">Pages needed:</span>
        <div class="choice-group">
          <div class="choice-item">
            <input type="checkbox" name="pages[]" id="page_home" value="Home" />
            <label for="page_home"><span class="box"></span> Home</label>
          </div>
          <div class="choice-item">
            <input type="checkbox" name="pages[]" id="page_about" value="About" />
            <label for="page_about"><span class="box"></span> About</label>
          </div>
          <div class="choice-item">
            <input type="checkbox" name="pages[]" id="page_services" value="Services" />
            <label for="page_services"><span class="box"></span> Services</label>
          </div>
          <div class="choice-item">
            <input type="checkbox" name="pages[]" id="page_contact" value="Contact" />
            <label for="page_contact"><span class="box"></span> Contact</label>
          </div>
          <div class="choice-item">
            <input type="checkbox" name="pages[]" id="page_landing" value="Landing Pages" />
            <label for="page_landing"><span class="box"></span> Landing Pages</label>
          </div>
        </div>
      </div>
      <div class="field">
        <span class="field-label">Languages:</span>
        <div class="choice-group">
          <div class="choice-item">
            <input type="checkbox" name="languages[]" id="lang_en" value="English" />
            <label for="lang_en"><span class="box"></span> English</label>
          </div>
          <div class="choice-item">
            <input type="checkbox" name="languages[]" id="lang_es" value="Spanish" />
            <label for="lang_es"><span class="box"></span> Spanish</label>
          </div>
          <div class="choice-item">
            <input type="checkbox" name="languages[]" id="lang_ru" value="Russian" />
            <label for="lang_ru"><span class="box"></span> Russian</label>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- SECTION 8 -->
  <div class="section-card">
    <div class="section-head">
      <div class="section-num">8</div>
      <div class="section-title">Forms</div>
    </div>
    <div class="section-body">
      <div class="field">
        <span class="field-label">Forms needed:</span>
        <div class="choice-group">
          <div class="choice-item">
            <input type="checkbox" name="forms_needed[]" id="form_contact" value="Contact form" />
            <label for="form_contact"><span class="box"></span> Contact form</label>
          </div>
          <div class="choice-item">
            <input type="checkbox" name="forms_needed[]" id="form_application" value="Application form" />
            <label for="form_application"><span class="box"></span> Application form</label>
          </div>
          <div class="choice-item">
            <input type="checkbox" name="forms_needed[]" id="form_survey" value="Survey" />
            <label for="form_survey"><span class="box"></span> Survey</label>
          </div>
        </div>
      </div>
      <div class="field">
        <label>Fields required in your forms</label>
